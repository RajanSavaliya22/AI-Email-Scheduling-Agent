// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  googleId      String?   @unique
  createdAt     DateTime  @default(now())

  tokens        OAuthToken?
  preferences   Preference?
  emails        Email[]
  events        CalendarEvent[]
}

model OAuthToken {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  accessToken   String
  refreshToken  String
  expiryDate    BigInt
  scope         String
}

model Preference {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  workingHoursStart Int      @default(9) // 24hr format, e.g. 9 = 9am
  workingHoursEnd   Int      @default(17) // 17 = 5pm
  meetingBufferMins Int      @default(15)
  defaultMeetingMins Int     @default(30)
  timezone          String   @default("Asia/Kolkata")
  tonePreference      String   @default("professional") // "professional" | "casual" | "concise"
  vipContacts         VipContact[]

}

model VipContact {
  id            String     @id @default(uuid())
  preferenceId  String
  preference    Preference @relation(fields: [preferenceId], references: [id])
  email         String
  label         String?    // e.g. "Manager", "Key Client"

  @@unique([preferenceId, email])
}

model Email {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  gmailId         String    @unique
  threadId        String
  sender          String
  subject         String
  bodyRaw         String
  summary         String?
  priority        String?
  actionItems     Json?
  suggestedReply  String?
  editedReply     String?   // user's edited version, if they changed the draft
  status          String    @default("unread")
  // unread -> summarized -> draft_pending -> approved -> sent
  //                                       -> rejected
  sentAt          DateTime?
  receivedAt      DateTime
  createdAt       DateTime  @default(now())
  notifiedAt    DateTime?
}

model CalendarEvent {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  startTime     DateTime
  endTime       DateTime
  status        String    @default("proposed") // proposed, confirmed, cancelled
  googleEventId String?   // set once actually created on Google Calendar
  createdAt     DateTime  @default(now())
}