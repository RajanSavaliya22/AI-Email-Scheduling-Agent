// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  googleId      String?   @unique
  createdAt     DateTime  @default(now())

  tokens        OAuthToken?
  preferences   Preference?
  emails        Email[]
  events        CalendarEvent[]
}

model OAuthToken {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  accessToken   String
  refreshToken  String
  expiryDate    BigInt
  scope         String
}

model Preference {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  workingHoursStart Int      @default(9)
  workingHoursEnd   Int      @default(17)
  meetingBufferMins Int      @default(15)
  timezone          String   @default("UTC")
}

model Email {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  gmailId       String    @unique   // <-- prevents duplicate ingestion
  threadId      String
  sender        String
  subject       String
  bodyRaw       String
  summary       String?
  priority      String?
  actionItems   Json?
  status        String    @default("unread")
  receivedAt    DateTime
  createdAt     DateTime  @default(now())
}

model CalendarEvent {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  startTime     DateTime
  endTime       DateTime
  status        String    @default("proposed") // proposed, confirmed, cancelled
  createdAt     DateTime  @default(now())
}